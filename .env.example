# -----------------------------------------------------------------------------
# DATABASE
# -----------------------------------------------------------------------------
# Local dev (Docker Compose) — set DIRECT_URL to the same value:
DATABASE_URL="postgresql://sidekit:sidekit@localhost:5433/sidekit?schema=public"
DIRECT_URL="postgresql://sidekit:sidekit@localhost:5433/sidekit?schema=public"

# Production (Vercel Postgres / Prisma Postgres / Neon):
#   DATABASE_URL  -> pooled connection (e.g. POSTGRES_PRISMA_URL on Vercel)
#   DIRECT_URL    -> direct/non-pooled connection (e.g. POSTGRES_URL_NON_POOLING)
# Both must be set. DIRECT_URL is only used by `prisma migrate` / `db push`;
# the app at runtime uses DATABASE_URL.

# -----------------------------------------------------------------------------
# AUTH
# -----------------------------------------------------------------------------
# Generate with:  openssl rand -base64 32
AUTH_SECRET=""
AUTH_TRUST_HOST=true
NEXTAUTH_URL="http://localhost:3000"
